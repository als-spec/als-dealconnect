From 2a7a292f33ed182f346a8fe73db9310266003da1 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Wed, 22 Apr 2026 19:06:42 +0000
Subject: [PATCH 2/2] Landing page: route all three subscription types
 correctly

Spec compliance: TC, Investor, and PML should each reach their correct
subscription plan from the landing page. Previously the PML path was
only accessible via the member-cards section below the fold, and the
hero 'I'm an Investor or Lender' button misrouted PMLs to the Investor
plan.

- LandingPage.jsx: Replace the 'I'm an Investor or Lender' hero link
  with a DropdownMenu that offers Investor and PML as distinct choices,
  each routing to the correct /onboarding?type=... URL.
- LandingPage.jsx: Add explicit ctaLabel to each MEMBER_CARDS entry
  instead of naively split role names ('Join as Transaction',
  'Join as Private'). New labels: 'Join as TC', 'Join as Investor',
  'Join as Lender'.
- PlanSelectionStep.jsx: Remove the silent '|| PLANS.investor' fallback
  that could bill PMLs for the Investor plan on missing member_type.
  Replace with an explicit error state that sends the user back to the
  member-type step.
---
 .../onboarding/PlanSelectionStep.jsx          | 19 ++++++-
 src/pages/LandingPage.jsx                     | 55 ++++++++++++++++---
 2 files changed, 65 insertions(+), 9 deletions(-)

diff --git a/src/components/onboarding/PlanSelectionStep.jsx b/src/components/onboarding/PlanSelectionStep.jsx
index b030795..f9b7b4c 100644
--- a/src/components/onboarding/PlanSelectionStep.jsx
+++ b/src/components/onboarding/PlanSelectionStep.jsx
@@ -49,7 +49,24 @@ const PLANS = {
 export default function PlanSelectionStep({ memberType, onBack, paymentError }) {
   const [loading, setLoading] = useState(false);
   const [checkoutError, setCheckoutError] = useState("");
-  const plan = PLANS[memberType] || PLANS.investor;
+  const plan = PLANS[memberType];
+
+  // Guard: if member_type isn't set (URL tamper, stale state, or a bug in the
+  // previous step's save), do NOT silently default to Investor — that risks
+  // billing and routing users to the wrong role. Send them back to pick a type.
+  if (!plan) {
+    return (
+      <div className="space-y-6 text-center">
+        <h2 className="text-2xl font-bold text-navy">We couldn't load your plan</h2>
+        <p className="text-slate-text max-w-md mx-auto">
+          It looks like your member type wasn't saved. Please go back and select your role so we can show you the right plan.
+        </p>
+        <Button onClick={onBack} className="gradient-primary text-white">
+          Back to Member Type
+        </Button>
+      </div>
+    );
+  }
 
   const handleCheckout = async () => {
     setLoading(true);
