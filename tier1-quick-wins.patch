index 14a70c5..d06ec43 100644
--- a/eslint.config.js
+++ b/eslint.config.js
@@ -55,6 +55,7 @@ export default [
         { ignore: ["cmdk-input-wrapper", "toast-close"] },
       ],
       "react-hooks/rules-of-hooks": "error",
+      "react-hooks/exhaustive-deps": "warn",
     },
   },
 ];
