From be35b684f90ee0b857d86e01addec53eb5b22f89 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Thu, 23 Apr 2026 23:00:22 +0000
Subject: [PATCH] Fix unauth navigation: move navigateToLogin into useEffect
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Unauthenticated visitors clicking any landing-page CTA that points to
a non-public path (e.g. 'I'm a TC' → /onboarding?type=tc) weren't
getting redirected to Base44's login page. The URL didn't change at
all. Meanwhile the Sign In button worked fine.

Root cause

Before this fix, App.jsx called navigateToLogin() synchronously
during render:

  if (authError.type === 'auth_required') {
    if (publicPaths.includes(currentPath)) { return <Routes>...</Routes>; }
    navigateToLogin();  // ← side effect during render
    return null;
  }

navigateToLogin() calls base44.auth.redirectToLogin(), which sets
window.location. Setting window.location during render is a side
effect that React silently swallows in strict mode (and which is
unreliable in general) — the redirect gets queued but never runs,
so the click appears to do nothing while the URL is briefly mid-
transition. React also warns about this pattern in dev mode with
'Cannot update a component while rendering a different component'.

Sign In worked because it called the same redirect from an onClick
handler — post-render, in an event handler context, where side
effects are legal.

Why this only surfaced now

This code path only executes for unauthenticated visitors on a
non-public path. Before the app was set to 'Public (login required)'
in Base44, Base44 itself intercepted every request and redirected
to login before the React SPA even booted — so App.jsx's
auth_required branch never actually ran for unauth users.

Now that the SPA boots for unauth users, the pre-existing bug is
reachable. The signup-flow-fix PR did NOT cause this; it was latent.

The fix

Extract the redirect into a tiny helper component that runs the
call inside useEffect:

  function RedirectToLogin({ navigateToLogin }) {
    useEffect(() => { navigateToLogin(); }, [navigateToLogin]);
    return null;
  }

Return <RedirectToLogin navigateToLogin={navigateToLogin} /> from
the auth_required + non-public-path branch instead of calling the
function inline. React runs the effect after commit, the redirect
fires, and the app navigates away to /login as expected.

navigateToLogin passed as prop (not pulled from useAuth inside the
helper) to keep the component dumb and testable.

Files (1):
  - src/App.jsx (+39/-2; most new lines are the explanatory comment
    above the RedirectToLogin helper)

Verification:
  - npm run lint: 0 errors
  - npm run build: succeeds

Deploy requirement: merge + Base44 Publish (as always for
custom-domain deploys).
---
 src/App.jsx | 41 +++++++++++++++++++++++++++++++++++++++--
 1 file changed, 39 insertions(+), 2 deletions(-)

diff --git a/src/App.jsx b/src/App.jsx
index dbcb094..a900f39 100644
--- a/src/App.jsx
+++ b/src/App.jsx
@@ -1,4 +1,5 @@
 import { Toaster } from "@/components/ui/toaster";
+import { useEffect } from "react";
 import { QueryClientProvider } from "@tanstack/react-query";
 import { queryClientInstance } from "@/lib/query-client";
 import { BrowserRouter as Router, Route, Routes, Navigate } from "react-router-dom";
@@ -14,6 +15,26 @@ import Onboarding from "./pages/Onboarding";
 import LandingPage from "./pages/LandingPage";
 import PartnersPage from "./pages/PartnersPage";
 
+/**
+ * Fires navigateToLogin() once after mount, then renders nothing.
+ *
+ * Exists specifically to avoid calling a side effect (window.location
+ * redirect) synchronously during render. When we detect an
+ * unauthenticated visitor on a non-public path, we return this
+ * component instead of calling navigateToLogin() inline — React runs
+ * the effect on commit, the redirect fires, and the app is unmounted
+ * as the page navigates away.
+ *
+ * navigateToLogin is passed as a prop rather than pulled via useAuth()
+ * so this stays a dumb component with a single responsibility.
+ */
+function RedirectToLogin({ navigateToLogin }) {
+  useEffect(() => {
+    navigateToLogin();
+  }, [navigateToLogin]);
+  return null;
+}
+
 const AuthenticatedApp = () => {
   const { isLoadingAuth, isLoadingPublicSettings, authError, navigateToLogin } = useAuth();
 
@@ -71,8 +92,24 @@ const AuthenticatedApp = () => {
           </Routes>
         );
       }
-      navigateToLogin();
-      return null;
+      // Unauthenticated visitor tried to navigate to a non-public path
+      // (e.g. clicked 'I'm a TC' → /onboarding?type=tc). Redirect them
+      // to Base44's login page, which offers both Sign In and Sign Up
+      // for new users.
+      //
+      // CRITICAL: this has to run in a useEffect, NOT synchronously
+      // during render. Calling navigateToLogin() (which calls
+      // base44.auth.redirectToLogin, which sets window.location) during
+      // render is a side effect that React silently swallows in strict
+      // mode, making the click appear to do nothing while the URL is
+      // mid-change. Running it in useEffect defers to the post-commit
+      // phase where side effects are legal.
+      //
+      // The <Navigate to="/" /> catch-all in the publicPaths branch
+      // above would also fight us here if we rendered it — the URL
+      // would bounce back to / before the effect fired. Returning null
+      // + effect is the correct shape.
+      return <RedirectToLogin navigateToLogin={navigateToLogin} />;
     }
   }
 
