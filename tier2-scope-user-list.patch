-    );
+    const pendingUsers = pendingUsersRaw.filter(u => !appUserIds.has(u.id));
     const syntheticApps = pendingUsers.map(u => ({
       id: "user_" + u.id,
       user_id: u.id,
diff --git a/src/pages/admin/Members.jsx b/src/pages/admin/Members.jsx
index a1e4615..2ff4d8e 100644
--- a/src/pages/admin/Members.jsx
