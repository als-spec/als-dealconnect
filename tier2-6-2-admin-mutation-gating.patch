From 15861057c7cd0dc39a0a669547ec49044d4b447c Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Thu, 23 Apr 2026 14:19:32 +0000
Subject: [PATCH] T2.6.2: Hide mutation affordances for admin (oversight-only)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Follow-up to T2.6.1. Per the product spec 'admins should only need to
see the pages, not engage as a network member', hides the remaining
mutation affordances that would let admin act as a transaction
participant on pages they can now view.

Scope: much smaller than initially estimated. Most affordances were
ALREADY correctly gated by pre-existing role checks that didn't
include admin:

  Already correctly gated (no change needed):
  - DealBoard 'Post a Deal'    — gated by isInvestor (admin != investor)
  - DealBoard 'Edit Deal'      — same isInvestor check on DealCard
  - DealDetailModal 'Apply'    — gated by userRole === 'tc'
  - RequestList 'New Request'  — gated by currentUserRole !== 'admin'
    (added back in T2.4b as defensive coding — now load-bearing)
  - Profile 'Edit Profile'     — gated by isOwner (admin no profile)
  - Messages / SupportTickets  — admin has no route access (T2.6.1)

That left three places where admin CAN still act as participant, now
fixed:

1. RequestDetail 'Mark as <next-status>' button
   canAdvanceStatus() was returning true for admin. Changed to TC-only.
   Investors were already read-only on the stepper. Admin now joins
   them in oversight mode.

2. DocumentsSection 'Upload' button
   Added canUpload = role !== 'admin' check. Admin sees the document
   list for oversight but cannot add documents. Upload button is
   hidden (not just disabled).

3. CommentsSection composer (textarea + send button)
   Added canPost = role !== 'admin' check. Admin can read the
   conversation for oversight but cannot post new comments. Composer
   is hidden entirely. Existing comments still render normally.

Files (3):
  - src/lib/serviceRequestUtils.js     (+3/-2)
      canAdvanceStatus now returns true only for TC
      Updated docstring to explain admin's oversight role

  - src/components/service-requests/DocumentsSection.jsx  (+5/-2)
      Wrapped upload button in canUpload conditional
      Document list always renders (oversight read access)

  - src/components/service-requests/CommentsSection.jsx   (+4/-3)
      Wrapped composer in canPost conditional
      Comment thread always renders (oversight read access)

What's preserved:
- Admin still sees the full ServiceRequest detail pane (header,
  stepper, timestamps, notes, documents, comments) — oversight needs
  visibility, not just access to bare routes
- Admin still has full engagement via /admin/* routes (Applications,
  Members, Partners, AdminDashboard approve/reject)
- TC, investor, PML experience is 100% unchanged — they see the same
  buttons they always did
- Existing T2.5 race fixes remain intact in DocumentsSection and
  CommentsSection (canUpload/canPost just wraps the UI; handlers are
  unchanged and still defensively validate user presence)

Verification:
- npm run lint: 0 errors (full codebase)
- npm run build: succeeds
- Manual trace through every mutation surface on every T2.6.1-
  accessible page confirms admin has no action-taking UI visible
---
 .../service-requests/CommentsSection.jsx      | 51 ++++++++++---------
 .../service-requests/DocumentsSection.jsx     | 40 ++++++++-------
 src/lib/serviceRequestUtils.js                | 10 ++--
 3 files changed, 58 insertions(+), 43 deletions(-)

diff --git a/src/components/service-requests/CommentsSection.jsx b/src/components/service-requests/CommentsSection.jsx
index 4e80cc2..33dc262 100644
--- a/src/components/service-requests/CommentsSection.jsx
+++ b/src/components/service-requests/CommentsSection.jsx
@@ -58,6 +58,9 @@ export default function CommentsSection({ request, currentUser, onUpdated }) {
   };
 
   const comments = request?.comments || [];
+  // Admin is oversight-only (T2.6.2): can read the conversation but
+  // doesn't post comments. TC/investor are the conversation participants.
+  const canPost = currentUser?.role && currentUser.role !== "admin";
 
   return (
     <div>
@@ -91,29 +94,31 @@ export default function CommentsSection({ request, currentUser, onUpdated }) {
           );
         })}
       </div>
-      <div className="flex gap-2">
-        <Textarea
-          value={newComment}
-          onChange={e => setNewComment(e.target.value)}
-          onKeyDown={e => {
-            if (e.key === 'Enter' && !e.shiftKey) {
-              e.preventDefault();
-              handlePost();
-            }
-          }}
-          placeholder="Add a comment…"
-          className="flex-1 min-h-[40px] max-h-[100px] resize-none text-sm"
-          rows={1}
-        />
-        <button
-          onClick={handlePost}
-          disabled={!newComment.trim() || posting}
-          className="gradient-primary text-white p-2.5 rounded-xl disabled:opacity-40 hover:opacity-90 transition-opacity flex-shrink-0"
-          aria-label="Post comment"
-        >
-          <Send className="w-4 h-4" />
-        </button>
-      </div>
+      {canPost && (
+        <div className="flex gap-2">
+          <Textarea
+            value={newComment}
+            onChange={e => setNewComment(e.target.value)}
+            onKeyDown={e => {
+              if (e.key === 'Enter' && !e.shiftKey) {
+                e.preventDefault();
+                handlePost();
+              }
+            }}
+            placeholder="Add a comment…"
+            className="flex-1 min-h-[40px] max-h-[100px] resize-none text-sm"
+            rows={1}
+          />
+          <button
+            onClick={handlePost}
+            disabled={!newComment.trim() || posting}
+            className="gradient-primary text-white p-2.5 rounded-xl disabled:opacity-40 hover:opacity-90 transition-opacity flex-shrink-0"
+            aria-label="Post comment"
+          >
+            <Send className="w-4 h-4" />
+          </button>
+        </div>
+      )}
     </div>
   );
 }
diff --git a/src/components/service-requests/DocumentsSection.jsx b/src/components/service-requests/DocumentsSection.jsx
index 5b01951..1dc8797 100644
--- a/src/components/service-requests/DocumentsSection.jsx
+++ b/src/components/service-requests/DocumentsSection.jsx
@@ -74,28 +74,34 @@ export default function DocumentsSection({ request, currentUser, onUpdated }) {
   };
 
   const documents = request?.documents || [];
+  // Admin is oversight-only (T2.6.2): can see the document list but
+  // doesn't upload documents themselves. TC/investor are the transaction
+  // participants who upload.
+  const canUpload = currentUser?.role && currentUser.role !== "admin";
 
   return (
     <div>
       <div className="flex items-center justify-between mb-2">
         <h4 className="font-bold text-navy text-sm">Documents</h4>
-        <div>
-          <input
-            type="file"
-            ref={fileInputRef}
-            onChange={handleUpload}
-            className="hidden"
-          />
-          <button
-            onClick={() => fileInputRef.current?.click()}
-            disabled={uploading}
-            className="flex items-center gap-1.5 text-xs text-teal font-semibold hover:opacity-80 transition-opacity"
-            aria-label="Upload a document"
-          >
-            <Upload className="w-3.5 h-3.5" />
-            {uploading ? "Uploading…" : "Upload"}
-          </button>
-        </div>
+        {canUpload && (
+          <div>
+            <input
+              type="file"
+              ref={fileInputRef}
+              onChange={handleUpload}
+              className="hidden"
+            />
+            <button
+              onClick={() => fileInputRef.current?.click()}
+              disabled={uploading}
+              className="flex items-center gap-1.5 text-xs text-teal font-semibold hover:opacity-80 transition-opacity"
+              aria-label="Upload a document"
+            >
+              <Upload className="w-3.5 h-3.5" />
+              {uploading ? "Uploading…" : "Upload"}
+            </button>
+          </div>
+        )}
       </div>
       {documents.length === 0 ? (
         <p className="text-sm text-muted-foreground">No documents uploaded yet.</p>
diff --git a/src/lib/serviceRequestUtils.js b/src/lib/serviceRequestUtils.js
index 932b61b..f5ebd78 100644
--- a/src/lib/serviceRequestUtils.js
+++ b/src/lib/serviceRequestUtils.js
@@ -44,9 +44,13 @@ export function formatRequestDate(d) {
 
 /**
  * Can this user advance the status of a ServiceRequest?
- * Only TCs and admins can advance status. Investors are read-only on the
- * stepper.
+ *
+ * Only TCs can advance status — they are the workflow owners for the
+ * transaction. Investors are read-only on the stepper (they wait for
+ * the TC to move things forward). Admin is oversight-only (T2.6.2) —
+ * admin can see the stepper but doesn't push transactions through it.
+ * PMLs don't participate in the TC/investor ServiceRequest flow.
  */
 export function canAdvanceStatus(userRole) {
-  return userRole === "tc" || userRole === "admin";
+  return userRole === "tc";
 }
